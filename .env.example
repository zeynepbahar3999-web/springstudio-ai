# fal.ai API key (sunucuda gizli kalır, kullanıcı görmez)
FAL_KEY=your_fal_ai_key_here

# Davet kodları (virgülle ayrılmış)
INVITE_CODES=spring2026,creator-beta,studio-pro

# JWT secret (rastgele uzun string)
JWT_SECRET=change-this-to-a-random-64-char-string

# Opsiyonel: domain
NEXT_PUBLIC_APP_URL=https://springstudio.ai
